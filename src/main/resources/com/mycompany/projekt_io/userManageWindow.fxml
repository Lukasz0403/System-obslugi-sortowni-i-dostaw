<?xml version="1.0" encoding="UTF-8"?>

<!-- imports -->

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- -->

<AnchorPane id="AnchorPane" prefHeight="750.0" prefWidth="950.0" style="-fx-background-color: #F7F5E6;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.projekt_io.UserManageWindowController">
    <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <!-- SIDEBAR -->
        <VBox prefWidth="83.0" style="-fx-background-color: #52658F;">
            <VBox alignment="CENTER" prefHeight="83.0" spacing="10.0">
                <ImageView fitHeight="60.0" fitWidth="60.0">
                    <image>
                        <Image url="@/logo.png" />
                    </image>
                </ImageView>
            </VBox>

            <VBox alignment="CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="homeButton" maxWidth="60.0" onAction="#handleHomeButton" prefHeight="40.0" style="-fx-background-color: #333a56; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold;" text="HOME" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="magButton" maxWidth="60.0" onAction="#handleMagButton" prefHeight="40.0" style="-fx-background-color: #333a56; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold;" text="MAG" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="pacButton" maxWidth="60.0" onAction="#handlePacButton" prefHeight="40.0" style="-fx-background-color: #333a56; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold;" text="PAC" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="addButton" maxWidth="60.0" onAction="#handleUserButton" prefHeight="40.0" style="-fx-background-color: #333a56; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold;" text="USER" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="logOut" maxWidth="60.0" prefHeight="40.0" style="-fx-background-color: #A94442; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 10px;" text="LOGOUT" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="closeApp" maxWidth="60.0" prefHeight="40.0" style="-fx-background-color: #A94442; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 10px;" text="CLOSE" />
                <Region VBox.vgrow="ALWAYS" />
            </VBox>

            <VBox alignment="CENTER" maxWidth="Infinity" spacing="2.0" style="-fx-padding: 0 15 5 15;">
                <Label fx:id="timeLabel" style="-fx-text-fill: white; -fx-font-size: 9.5px; -fx-font-weight: bold;" text="HH:mm" />
                <Label fx:id="dateLabel" style="-fx-text-fill: white; -fx-font-size: 9.5px; -fx-font-weight: bold;" text="YYYY-MM-DD" />
            </VBox>
        </VBox>

        <!-- MAIN -->
        <VBox spacing="0.0" HBox.hgrow="ALWAYS">

            <!-- TOP BAR -->
            <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="10.0" style="-fx-background-color: #e8e6d8; -fx-padding: 0 15 0 15;">
                <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333a56;" text="User Management" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="refresh" onAction="#handleUserButton" style="-fx-background-color: #d4d2c4; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="Reload Page" />
                <Button fx:id="addUserButton" onAction="#handleAddUser" style="-fx-background-color: #52658F; -fx-text-fill: white; -fx-cursor: hand;" text="+ Add User" />
            </HBox>

            <!-- COLUMN HEADERS -->
            <HBox prefHeight="30.0" style="-fx-background-color: #d4d2c4; -fx-padding: 0 15 0 15;">
                <Label prefWidth="150.0" style="-fx-font-weight: bold; -fx-text-fill: #333a56;" text="Login" />
                <Label prefWidth="120.0" style="-fx-font-weight: bold; -fx-text-fill: #333a56;" text="Role" />
                <Region HBox.hgrow="ALWAYS" />
                <Label prefWidth="60.0" style="-fx-font-weight: bold; -fx-text-fill: #333a56;" text="Actions" />
            </HBox>

            <!-- USER LIST -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #F7F5E6;" VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="userListContainer" spacing="0.0" />
                </content>
            </ScrollPane>

        </VBox>
    </HBox>
</AnchorPane>
