                           </font></Label>
                     </children>
                  </AnchorPane>
               </children></HBox>
            
            <HBox layoutX="313.0" prefHeight="750.0" prefWidth="552.0">
               <children>
                  <AnchorPane prefHeight="750.0" prefWidth="548.0">
