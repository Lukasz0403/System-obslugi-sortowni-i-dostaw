        <VBox prefWidth="83.0" style="-fx-background-color: #52658F;">

            <!-- LOGO -->
            <VBox alignment="CENTER" prefHeight="83.0" spacing="10.0">
                <Circle fill="#333a56" radius="24.0" />
            </VBox>

            <!-- Przyciski -->
            <VBox alignment="CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="homeButton" maxWidth="60.0" text="HOME" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="magButton" maxWidth="60.0" text="MAG" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="pacButton" maxWidth="60.0" text="PAC" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="addButton" maxWidth="60.0" text="USER" />
                <Region VBox.vgrow="ALWAYS" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="logOut" maxWidth="60.0" style="-fx-font-size: 10px;" text="LOGOUT" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="closeApp" maxWidth="60.0" style="-fx-font-size: 10px;" text="CLOSE" />
                <Region VBox.vgrow="ALWAYS" />
            </VBox>

            <!-- TIME AND DATE -->
            <VBox alignment="CENTER" maxWidth="Infinity" spacing="2.0" style="-fx-padding: 0 15 5 15;">
                <Label fx:id="timeLabel" style="-fx-text-fill: white; -fx-font-size: 10px;" text="HH:mm">
                    <font><Font size="5.0" /></font>
                </Label>
                <Label fx:id="dateLabel" style="-fx-text-fill: white; -fx-font-size: 10px;" text="YYYY-MM-DD">
                    <font><Font size="5.0" /></font>
                </Label>
            </VBox>

        </VBox>
        <!-- MAIN -->
        <AnchorPane HBox.hgrow="ALWAYS">
         <children>
            <HBox prefHeight="750.0" prefWidth="318.0">
               <children>
                  <AnchorPane prefHeight="750.0" prefWidth="315.0">
                     <children>
                        <Rectangle fill="aec1d1" height="249.0" layoutX="118.0" layoutY="108.0" stroke="#333333" strokeWidth="1" width="83.0" />       
                        <Rectangle fx:id="shelficon" fill="#ff4d4d" height="0.0" layoutX="118.0" layoutY="357.0" strokeWidth="0" width="83.0" />
                        <Label fx:id="occupancyLabel" alignment="CENTER" layoutX="118.0" layoutY="215.0" prefWidth="83.0" style="-fx-text-fill: rgba(255, 255, 255, 0.8); -fx-font-weight: bold; -fx-font-size: 14px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 2, 0, 0, 0);" text="0.0%" textAlignment="CENTER" />
                        <PieChart fx:id="shelfPieChart" layoutX="15.0" layoutY="437.0" prefHeight="290.0" prefWidth="289.0" />
                        <Label fx:id="rackIdLabel" alignment="CENTER" layoutX="15.0" layoutY="58.0" prefWidth="289.0" text="REGAŁ: --">
                           <font>
