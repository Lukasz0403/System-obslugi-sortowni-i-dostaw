<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="750.0" prefWidth="950.0" style="-fx-background-color: #F7F5E6;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.projekt_io.WarehouseInfoWindowController">

    <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <VBox prefWidth="83.0" style="-fx-background-color: #52658F;">
            <VBox alignment="CENTER" prefHeight="83.0" spacing="10.0">
                <Circle fill="#333a56" radius="24.0" />
            </VBox>

            <VBox alignment="CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="homeButton" maxWidth="60.0" text="HOME" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="magButton" maxWidth="60.0" text="MAG" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="pacButton" maxWidth="60.0" text="PAC" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="addButton" maxWidth="60.0" text="USER" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="logOut" maxWidth="60.0" style="-fx-font-size: 10px;" text="LOGOUT" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="closeApp" maxWidth="60.0" style="-fx-font-size: 10px;" text="CLOSE" />
                <Region VBox.vgrow="ALWAYS" />
            </VBox>

            <VBox alignment="CENTER" maxWidth="Infinity" spacing="2.0" style="-fx-padding: 0 15 5 15;">
                <Label fx:id="timeLabel" style="-fx-text-fill: white; -fx-font-size: 10px;" text="HH:mm" />
                <Label fx:id="dateLabel" style="-fx-text-fill: white; -fx-font-size: 10px;" text="YYYY-MM-DD" />
            </VBox>
        </VBox>

        <AnchorPane HBox.hgrow="ALWAYS">
            <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                <StackPane HBox.hgrow="ALWAYS" prefWidth="315.0">
                    <padding>
                        <Insets bottom="20" left="20" right="20" top="20" />
                    </padding>
                    <VBox alignment="CENTER" spacing="10">
                        <Label fx:id="rackIdLabel" style="-fx-font-weight: bold; -fx-font-size: 24px;" text="REGAŁ: --" />
                        
                        <StackPane alignment="BOTTOM_CENTER" maxHeight="249.0" maxWidth="83.0">
                            <Rectangle fill="#aec1d1" height="249.0" stroke="#333333" strokeWidth="1" width="83.0" />
                            <Rectangle fx:id="shelficon" fill="#ff4d4d" height="0.0" width="83.0" />
                        </StackPane>
                        
                        <Label fx:id="occupancyLabel" style="-fx-font-weight: bold; -fx-font-size: 14px;" text="0.0%" />
                        <PieChart fx:id="shelfPieChart" prefHeight="300.0" prefWidth="300.0" />
                    </VBox>
                </StackPane>

                <AnchorPane HBox.hgrow="ALWAYS" prefWidth="548.0">
                    <ScrollPane fitToHeight="true" fitToWidth="true" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                        <TableView fx:id="table2">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="colFormat" prefWidth="60.0" text="Format" />
                                <TableColumn fx:id="colOrigin" prefWidth="100.0" text="Nadanie" />
                                <TableColumn fx:id="colDest" prefWidth="100.0" text="Cel" />
                                <TableColumn fx:id="colSender" prefWidth="110.0" text="Nadawca" />
                                <TableColumn fx:id="colRecipient" prefWidth="110.0" text="Odbiorca" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </ScrollPane>
                </AnchorPane>
            </HBox>
        </AnchorPane>
    </HBox>
</AnchorPane>