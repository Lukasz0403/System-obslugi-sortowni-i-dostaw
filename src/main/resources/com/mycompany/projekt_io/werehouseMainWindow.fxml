<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #F7F5E6;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.projekt_io.WerehouseMainWindowController">

    <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <!-- SIDEBAR -->
        <VBox prefWidth="83.0" style="-fx-background-color: #52658F;">
            <!-- LOGO -->
            <VBox alignment="CENTER" prefHeight="83.0" spacing="10.0">
                <Circle fill="#333a56" radius="24.0" />
            </VBox>

            <!-- BUTTONS -->
            <VBox alignment="CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="magButton" maxWidth="60.0" text="MAG" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="pacButton" maxWidth="60.0" text="PAC" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="addButton" maxWidth="60.0" text="USER" />
                <Region VBox.vgrow="ALWAYS" />
            </VBox>

            <!-- TIME AND DATE -->
            <VBox alignment="CENTER" maxWidth="Infinity" spacing="2.0" style="-fx-padding: 0 15 5 15;">
                <Label fx:id="timeLabel" style="-fx-text-fill: white; -fx-font-size: 10px;" text="HH:mm">
                    <font><Font size="5.0" /></font>
                </Label>
                <Label fx:id="dateLabel" style="-fx-text-fill: white; -fx-font-size: 10px;" text="YYYY-MM-DD">
                    <font><Font size="5.0" /></font>
                </Label>
            </VBox>
        </VBox>

        <!-- MAIN -->
        <AnchorPane fx:id="mainPane" HBox.hgrow="ALWAYS">

            <!-- REGAŁY -->
            <Rectangle fx:id="shelf1" fill="#aec1d1" width="77" height="209" layoutX="417" layoutY="28" stroke="#333333" strokeWidth="0"/>
            <Rectangle fx:id="shelf2" fill="#aec1d1" width="77" height="209" layoutX="326" layoutY="28" stroke="#333333" strokeWidth="0"/>
            <Rectangle fx:id="shelf3" fill="#aec1d1" width="77" height="209" layoutX="231" layoutY="28" stroke="#333333" strokeWidth="0"/>
            <Rectangle fx:id="shelf4" fill="#aec1d1" width="77" height="209" layoutX="139" layoutY="28" stroke="#333333" strokeWidth="0"/>
            <Rectangle fx:id="shelfex" fill="#cfaeb9" width="77" height="209" layoutX="33" layoutY="28" stroke="#333333" strokeWidth="0"/>

            <!-- INFO PANEL - SHOWS ON SHELF HOVER -->
            <VBox fx:id="infoPanel" layoutX="0" layoutY="0" visible="false" spacing="4"
                  style="-fx-background-color: white; -fx-border-color: #52658F; -fx-padding: 8; -fx-effect: dropshadow(gaussian, gray, 5, 0.5, 2, 2);">
                <Label fx:id="infoShelfId" text="Shelf: " style="-fx-font-weight: bold;"/>
                <Label fx:id="infoPackageCount" text="Packages: "/>
                <Label fx:id="infoLastPackage" text="Last Package ID: "/>
                <Label fx:id="infoLastDate" text="Added: 00:00  0000-00-00"/>
                <Label fx:id="infoLastSender" text="By: "/>
            </VBox>

            <!-- TABLE -->
            <AnchorPane layoutX="16.0" layoutY="254.0" prefHeight="130.0" prefWidth="482.0">
                <children>
                    <ScrollPane fitToWidth="true" fitToHeight="true"
                                AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                                AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
                        <content>
                            <TableView fx:id="warehouseTable" prefHeight="130.0" prefWidth="482.0">
                                <columns>
                                    <TableColumn fx:id="colTotalPackages" prefWidth="120.0" text="Total Packages"/>
                                    <TableColumn fx:id="colZone1" prefWidth="90.0" text="Zone 1"/>
                                    <TableColumn fx:id="colZone2" prefWidth="90.0" text="Zone 2"/>
                                    <TableColumn fx:id="colZone3" prefWidth="90.0" text="Zone 3"/>
                                    <TableColumn fx:id="colEmptyShelves" prefWidth="100.0" text="Empty Shelves"/>
                                    <TableColumn fx:id="colBusiestShelf" prefWidth="110.0" text="Busiest Shelf"/>
                                </columns>
                            </TableView>
                        </content>
                    </ScrollPane>
                </children>
            </AnchorPane>

        </AnchorPane>
    </HBox>

</AnchorPane>