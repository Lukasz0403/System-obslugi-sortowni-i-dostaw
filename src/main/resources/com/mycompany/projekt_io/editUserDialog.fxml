<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="280.0" prefWidth="320.0" style="-fx-background-color: #F7F5E6;"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.projekt_io.EditUserDialogController">

    <VBox spacing="0.0" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <!-- TITLE BAR -->
        <HBox prefHeight="45.0" alignment="CENTER_LEFT" style="-fx-background-color: #52658F; -fx-padding: 0 15 0 15;">
            <Label text="Edit User" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />
        </HBox>

        <!-- FORM -->
        <VBox spacing="12.0" style="-fx-padding: 20 20 10 20;" VBox.vgrow="ALWAYS">
            <Label text="Login" style="-fx-text-fill: #333a56; -fx-font-weight: bold;" />
            <TextField fx:id="loginField" promptText="Enter new login" />

            <Label text="New Password" style="-fx-text-fill: #333a56; -fx-font-weight: bold;" />
            <PasswordField fx:id="passwordField" promptText="Enter new password" />

            <Label text="Role" style="-fx-text-fill: #333a56; -fx-font-weight: bold;" />
            <ChoiceBox fx:id="permissionChoiceBox" maxWidth="Infinity" />

            <Label fx:id="errorLabel" text="Method not finished - contact database administrator."
                   style="-fx-text-fill: #c0392b; -fx-font-size: 11px;" visible="false" />
        </VBox>

        <!-- BUTTONS -->
        <HBox spacing="10.0" alignment="CENTER_RIGHT" style="-fx-padding: 0 20 15 20;">
            <Button text="Cancel" onAction="#handleCancel"
                    style="-fx-background-color: #d4d2c4; -fx-cursor: hand;" />
            <Button text="Save Changes" onAction="#handleSave"
                    style="-fx-background-color: #52658F; -fx-text-fill: white; -fx-cursor: hand;" />
        </HBox>

    </VBox>
</AnchorPane>