            </Text>
            <Text fill="WHITE" layoutX="336.0" layoutY="137.0" strokeType="OUTSIDE" strokeWidth="0.0" text="CITY:">
               <font>
                  <Font size="10.0" />
               </font>
            </Text>
            <Text fill="WHITE" layoutX="336.0" layoutY="158.0" strokeType="OUTSIDE" strokeWidth="0.0" text="E-MAIL:">
               <font>
                  <Font size="10.0" />
               </font>
            </Text>
            <Text fx:id="nameText" fill="WHITE" layoutX="402.0" layoutY="73.0" strokeType="OUTSIDE" strokeWidth="0.0" text="None">
               <font>
                  <Font size="10.0" />
               </font>
            </Text>
            <Text fx:id="streetText" fill="WHITE" layoutX="403.0" layoutY="95.0" strokeType="OUTSIDE" strokeWidth="0.0" text="None">
               <font>
                  <Font size="10.0" />
               </font>
            </Text>
            <Text fx:id="codeText" fill="WHITE" layoutX="402.0" layoutY="117.0" strokeType="OUTSIDE" strokeWidth="0.0" text="None">
               <font>
                  <Font size="10.0" />
               </font>
            </Text>
            <Text fx:id="mailText" fill="WHITE" layoutX="402.0" layoutY="158.0" strokeType="OUTSIDE" strokeWidth="0.0" text="None">
               <font>
                  <Font size="10.0" />
               </font>
            </Text>
            <Button fx:id="loadTempButton" layoutX="350.0" layoutY="229.0" mnemonicParsing="false" onAction="#loadTemplate" prefHeight="26.0" prefWidth="134.0" text="LOAD TEMPLATE" />
            <Text fill="WHITE" layoutX="336.0" layoutY="179.0" strokeType="OUTSIDE" strokeWidth="0.0" text="NUMBER:">
               <font>
                  <Font size="10.0" />
               </font>
            </Text>
            <Text fx:id="numberText" fill="WHITE" layoutX="402.0" layoutY="179.0" strokeType="OUTSIDE" strokeWidth="0.0" text="None">
               <font>
                  <Font size="10.0" />
               </font>
            </Text>
            <Text fx:id="cityText" fill="WHITE" layoutX="402.0" layoutY="137.0" strokeType="OUTSIDE" strokeWidth="0.0" text="None">
               <font>
                  <Font size="10.0" />
               </font>
            </Text>
            <Button fx:id="clearTempButton" layoutX="349.0" layoutY="255.0" mnemonicParsing="false" onAction="#clearTemplate" prefHeight="26.0" prefWidth="134.0" text="CLEAR TEMPLATE" />
         </children></AnchorPane>

    </HBox>
</AnchorPane>
