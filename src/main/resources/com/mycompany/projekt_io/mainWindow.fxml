<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<AnchorPane id="AnchorPane" prefHeight="750.0" prefWidth="950.0" style="-fx-background-color: #F7F5E6;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.projekt_io.MainWindowController">

    <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <!-- SIDEBAR -->
        <VBox prefWidth="83.0" style="-fx-background-color: #52658F;">
            <VBox alignment="CENTER" prefHeight="83.0" spacing="10.0">
                <Circle fill="#333a56" radius="24.0" />
            </VBox>

            <VBox alignment="CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="homeButton" maxWidth="60.0" onAction="#handleHomeButton" text="HOME" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="magButton" maxWidth="60.0" onAction="#handleMagButton" text="MAG" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="pacButton" maxWidth="60.0" onAction="#handlePacButton" text="PAC" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="addButton" maxWidth="60.0" onAction="#handleUserButton" text="USER" />
                <Region VBox.vgrow="ALWAYS" />
            </VBox>

            <VBox alignment="CENTER" maxWidth="Infinity" spacing="2.0" style="-fx-padding: 0 15 5 15;">
                <Label fx:id="timeLabel" style="-fx-text-fill: white; -fx-font-size: 10px;" text="HH:mm" />
                <Label fx:id="dateLabel" style="-fx-text-fill: white; -fx-font-size: 10px;" text="YYYY-MM-DD" />
            </VBox>
        </VBox>

        <!-- MAIN DASHBOARD -->
        <VBox alignment="CENTER" spacing="20.0" HBox.hgrow="ALWAYS" style="-fx-padding: 40;">
            <VBox alignment="CENTER_LEFT" spacing="5.0">
                <Text fill="#52658f" style="-fx-font-size: 32px; -fx-font-weight: bold;" text="Dashboard" />
                <Separator prefWidth="200.0" />
            </VBox>

            <HBox alignment="CENTER" spacing="30.0" VBox.vgrow="ALWAYS">
                <!-- User Info Card -->
                <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Circle fill="#aec1d1" radius="20.0" />
                        <VBox>
                            <Label fx:id="userNameLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="User Name" />
                            <Label fx:id="userRoleLabel" style="-fx-text-fill: gray;" text="Administrator" />
                        </VBox>
                    </HBox>
                    
                    <Separator />
                    
                    <GridPane vgap="10.0" hgap="15.0">
                        <Label text="User ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;" />
                        <Label fx:id="userIdLabel" text="#12345" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        
                        <Label text="Session Start:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;" />
                        <Label fx:id="sessionStartLabel" text="10:00:00" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    </GridPane>
                </VBox>

                <!-- Status Summary Quick View -->
                <VBox alignment="CENTER" spacing="10.0">
                    <Text fill="#52658f" style="-fx-font-size: 18px;" text="Welcome back!" />
                    <Label text="System is running normally" style="-fx-text-fill: green; -fx-font-size: 12px;" />
                </VBox>
            </HBox>
        </VBox>

    </HBox>

</AnchorPane>